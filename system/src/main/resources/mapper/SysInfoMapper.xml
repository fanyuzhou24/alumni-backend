<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.alumni.system.mapper.SysInfoMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.alumni.system.domain.SysInfo">
        <id column="id" property="id" />
        <result column="system_name" property="systemName" />
        <result column="welcome_word" property="welcomeWord" />
        <result column="notice" property="notice" />
        <result column="carousel" property="carousel" />
        <result column="del_flag" property="delFlag" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, system_name, welcome_word, notice, carousel, del_flag
    </sql>

</mapper>
