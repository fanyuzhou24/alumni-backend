<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.alumni.system.mapper.DeptCircleCommentMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.alumni.system.domain.DeptCircleComment">
        <id column="id" property="id" />
        <result column="post_id" property="postId" />
        <result column="user_id" property="userId" />
        <result column="parent_id" property="parentId" />
        <result column="reply_user_id" property="replyUserId" />
        <result column="content" property="content" />
        <result column="del_flag" property="delFlag" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, post_id, user_id, parent_id, reply_user_id, content, del_flag
    </sql>
    <select id="listByPostId" resultType="com.alumni.system.domain.DeptCircleComment"
            parameterType="java.lang.Long">
        select d.*,
               su.user_name as userName,
               su2.user_name as replyUserName
            from dept_circle_comment d
            left join sys_user su on su.user_id = d.user_id
            left join sys_user su2 on su2.user_id = d.reply_user_id
            where
                d.post_id = #{postId}
                and d.del_flag = 0
            order by d.create_time desc
    </select>

</mapper>
